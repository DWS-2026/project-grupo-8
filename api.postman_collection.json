      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user1@example.com\",\n  \"password\": \"user123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "login"
              ]
            },
            "description": "Inicia sesión con un usuario de ejemplo. Postman conservará la cookie de sesión para las peticiones posteriores al mismo host."
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Example User\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"User12345!\",\n  \"password2\": \"User12345!\",\n  \"planId\": {{planId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "register"
              ]
            },
            "description": "Registra un usuario nuevo y devuelve el header Location con la URL del recurso creado."
          }
